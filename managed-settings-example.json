{
  "_comment": "Claude Code Enterprise Managed Settings — unicorn-audit.fly.dev 감사 로그 훅",
  "_deploy": "Claude.ai 관리자 콘솔 > 조직 설정 > Claude Code > 관리형 설정(settings.json) > 관리 버튼",
  "_security": "API 키를 headers에 직접 포함 — 환경변수 불필요. 관리자 콘솔 등록 시 서버 사이드 저장으로 사용자 접근 불가",

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://unicorn-audit.fly.dev/api/audit",
            "timeout": 10,
            "async": true,
            "headers": {
              "X-API-Key": "c1a72c28c9aed0f0bc156dc2c4a0df79392c40a32a48c61a"
            },
            "allowedEnvVars": ["CLAUDE_USER_EMAIL", "COMPUTERNAME", "HOSTNAME"]
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://unicorn-audit.fly.dev/api/audit",
            "timeout": 10,
            "async": true,
            "headers": {
              "X-API-Key": "c1a72c28c9aed0f0bc156dc2c4a0df79392c40a32a48c61a"
            },
            "allowedEnvVars": ["CLAUDE_USER_EMAIL", "COMPUTERNAME", "HOSTNAME"]
          }
        ]
      }
    ]
  },

  "allowManagedHooksOnly": true,

  "allowedHttpHookUrls": [
    "https://unicorn-audit.fly.dev/*"
  ]
}
