# PostgreSQL 설정
DB_NAME=auditdb
DB_USER=audituser
DB_PASSWORD=your-secure-password-here   # 필수: 빈 값 금지

# 서버 포트 (기본 3000)
PORT=3000

# API 인증 키 — Claude hook의 allowedEnvVars로 각 PC에 배포
# managed-settings.json 의 "Authorization": "Bearer $CLAUDE_AUDIT_API_KEY" 와 대응
API_KEY=your-api-key-here               # 필수: 충분히 긴 랜덤 문자열 사용
